# ---------------------------------------------------------------------------
# dex_trade_bot configuration. Copy to ".env" and fill in. NEVER commit ".env".
# ---------------------------------------------------------------------------

# --- Wallet (only secrets you must provide) --------------------------------
# In paper mode ONLY the address is used (read-only). PRIVATE_KEY is required
# only for EXECUTION_MODE=live. Keep this file out of git (.gitignore covers it).
WALLET_ADDRESS=0x0000000000000000000000000000000000000000
PRIVATE_KEY=

# --- Chain / RPC -----------------------------------------------------------
# Free public BSC RPC works for paper mode. WSS is optional, only needed for
# mempool watching and new-pair sniping.
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_WSS_URL=

# --- Execution mode --------------------------------------------------------
# paper = simulate fills against live quotes (no signing, no funds at risk).
# live  = sign and broadcast real transactions (requires PRIVATE_KEY).
EXECUTION_MODE=paper

# --- Risk limits (hard caps) -----------------------------------------------
STARTING_BALANCE_USD=30
MAX_POSITION_USD=5
MAX_TRADE_PCT=20
DAILY_LOSS_STOP_USD=8
MAX_SLIPPAGE_BPS=150
MAX_OPEN_POSITIONS=3
MIN_LIQUIDITY_USD=20000
MAX_BUY_TAX_PCT=8
PER_TOKEN_COOLDOWN_MIN=30

# --- Strategy selection (comma separated) ----------------------------------
# Available: momentum,meanrev,sniper,arbitrage,stablegrid,crossarb,liquidation
ENABLED_STRATEGIES=momentum,meanrev,stablegrid,arbitrage,sniper,crossarb,liquidation

# --- CEX (Binance) for hybrid CEX<->DEX --------------------------------------
# Paper mode uses PUBLIC prices and needs NO keys. Keys only for live CEX trading.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TLD=com
# Tokens compared across Binance vs BSC DEX (must be in COMMON_TOKENS map)
CROSSARB_SYMBOLS=CAKE,ETH,XRP
# Assumed cost (%) of moving funds between venues; gates cross-venue arb
CROSS_VENUE_TRANSFER_COST_PCT=1.0

# --- Lending / liquidations (Venus on BSC) ----------------------------------
# Comma-separated borrower addresses to monitor for liquidation shortfall.
VENUS_WATCH_ACCOUNTS=

# --- Intelligence layer ----------------------------------------------------
# Comma separated wallets to copy-trade (optional). Leave empty to disable.
WHALE_WATCHLIST=
ENABLE_MEMPOOL_WATCH=false

# --- Notifications (optional, apprise URL) ---------------------------------
APPRISE_URL=

# --- Loop timing -----------------------------------------------------------
SCOUT_SLEEP_TIME=15
